---
import { siteConfig } from "@/config";
import { musicPlayerConfig, type PlaylistConfig } from "@/config/musicConfig";
import { getCurrentLang } from "@/i18n/utils";
import { i18n } from "@/i18n/translation";
import I18nKey from "@/i18n/i18nKey";
import MainGridLayout from "@/layouts/MainGridLayout.astro";

const lang = getCurrentLang();

if (!siteConfig.pages.musicPage) {
	return Astro.redirect("/404/");
}

const playlists = musicPlayerConfig.playlists || [];

const platformNames: Record<string, string> = {
	netease: "网易云音乐",
	tencent: "QQ音乐",
	kugou: "酷狗音乐",
	xiami: "虾米音乐",
	baidu: "百度音乐",
};

const platformIcons: Record<string, string> = {
	netease: "🎵",
	tencent: "🎶",
	kugou: "🎧",
	xiami: "🎹",
	baidu: "🎼",
};
---

<MainGridLayout
	title={i18n(I18nKey.musicPageTitle)}
	description={i18n(I18nKey.musicPageDescription)}
>
	<div class="music-page-wrapper w-full">
		<div class="card-base px-6 pt-8 pb-8">
			<header class="music-header mb-6">
				<div class="mb-6">
					<div class="flex items-center gap-3 mb-3">
						<div class="h-8 w-8 rounded-lg bg-(--primary) flex items-center justify-center text-white dark:text-black/70">
							<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-[1.5rem]">
								<path d="M9 18V5l12-2v13" />
								<circle cx="6" cy="18" r="3" />
								<circle cx="18" cy="16" r="3" />
							</svg>
						</div>
						<div class="text-3xl font-bold text-neutral-900 dark:text-neutral-100">
							{i18n(I18nKey.musicPageTitle)}
						</div>
					</div>
					<p class="text-base text-neutral-600 dark:text-neutral-400 leading-relaxed">
						{i18n(I18nKey.musicPageDescription)}
					</p>
				</div>
			</header>

			{playlists.length > 0 && (
				<div class="playlists-section mb-6">
					<h2 class="text-lg font-semibold text-(--deep-text) mb-3">{i18n(I18nKey.musicPlaylist)}</h2>
					<div class="playlists-grid grid grid-cols-2 md:grid-cols-4 gap-3">
						{playlists.map((playlist: PlaylistConfig) => (
							<button
								key={playlist.id}
								class={`playlist-card p-4 rounded-xl border transition-all duration-200 text-left ${
									playlist.id === musicPlayerConfig.currentPlaylistId
										? "border-(--primary) bg-(--primary)/10"
										: "border-(--line-divider) bg-(--card-bg) hover:border-(--primary)/50"
								}`}
								data-playlist-id={playlist.id}
							>
								<div class="w-full aspect-square rounded-lg mb-3 overflow-hidden bg-(--btn-regular-bg) relative">
									{playlist.cover ? (
										<img
											src={playlist.cover}
											alt={playlist.name}
											class="w-full h-full object-cover"
											loading="lazy"
										/>
									) : (
										<div class="w-full h-full flex items-center justify-center">
											<span class="text-2xl">{platformIcons[playlist.server] || "🎵"}</span>
										</div>
									)}
								</div>
								<h3 class="text-sm font-semibold text-(--deep-text) truncate">{playlist.name}</h3>
								<p class="text-xs text-(--content-meta) truncate">{playlist.description}</p>
								<div class="mt-2 flex items-center gap-1">
									<span class="text-xs text-(--content-meta)/70">{platformNames[playlist.server] || playlist.server}</span>
								</div>
							</button>
						))}
					</div>
				</div>
			)}

			<div class="music-content flex flex-col lg:flex-row gap-6">
				<div class="flex-1">
					<div class="playlist-info mb-4">
						<div class="flex items-center justify-between">
							<div>
								<h2 class="text-xl font-bold text-(--deep-text)">
									{i18n(I18nKey.musicPlaylist)}
								</h2>
							</div>
							<button
								class="flex items-center gap-2 px-4 py-2 rounded-lg bg-(--primary) text-white text-sm font-medium hover:opacity-90 transition-opacity"
								onclick="window.__fireflyMusic?.togglePlay()"
							>
								<svg id="music-play-btn-icon" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5">
									<path d="M8 5v14l11-7z" />
								</svg>
								<span id="music-play-btn-text">{i18n(I18nKey.musicPlay)}</span>
							</button>
						</div>
					</div>

					<div class="playlist-tracks bg-(--card-bg) rounded-xl border border-(--line-divider) overflow-hidden">
						<div class="track-header grid grid-cols-12 gap-4 px-4 py-3 border-b border-(--line-divider) text-xs font-medium text-(--content-meta)">
							<div class="col-span-1">#</div>
							<div class="col-span-5 md:col-span-6">歌曲</div>
							<div class="col-span-4 md:col-span-3">歌手</div>
							<div class="col-span-2 md:col-span-2 text-right">时长</div>
						</div>
						<div id="music-track-list" class="track-list max-h-96 overflow-y-auto">
							<div class="flex items-center justify-center py-12 text-(--content-meta)">
								<div class="flex flex-col items-center gap-2">
									<div class="w-8 h-8 border-2 border-(--content-meta) border-t-transparent rounded-full animate-spin"></div>
									<span class="text-sm">加载歌曲...</span>
								</div>
							</div>
						</div>
					</div>
				</div>

				<div class="lg:w-80">
					<div class="player-panel bg-(--card-bg) rounded-xl border border-(--line-divider) p-4 sticky top-6">
						<div class="player-header flex gap-3 mb-4">
							<div class="player-cover w-20 h-20 flex-shrink-0 rounded-lg bg-(--btn-regular-bg) overflow-hidden">
								<img id="music-cover" src="" alt="Cover" class="w-full h-full object-cover hidden" />
								<div id="music-cover-placeholder" class="w-full h-full flex items-center justify-center">
									<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-8 h-8 text-(--content-meta)">
										<path d="M9 18V5l12-2v13" />
										<circle cx="6" cy="18" r="3" />
										<circle cx="18" cy="16" r="3" />
									</svg>
								</div>
							</div>
							<div class="player-info flex-1 flex flex-col justify-center">
								<h3 id="music-title" class="text-sm font-semibold text-(--deep-text) truncate">
									{i18n(I18nKey.musicNoPlaying)}
								</h3>
								<p id="music-artist" class="text-xs text-(--content-meta) truncate mt-1">
									-
								</p>
								<div id="music-current-lyric" class="text-xs text-(--primary) truncate mt-1">
									{i18n(I18nKey.musicNoLyrics)}
								</div>
							</div>
						</div>

						<div class="player-progress mb-4">
							<div class="flex items-center justify-between text-xs text-(--content-meta) mb-1">
								<span id="music-current-time">0:00</span>
								<span id="music-duration">0:00</span>
							</div>
							<div class="relative h-1.5 bg-(--btn-regular-bg) rounded-full overflow-hidden">
								<div id="music-progress-bar" class="absolute top-0 left-0 h-full bg-(--primary) rounded-full transition-all duration-100" style="width: 0%"></div>
								<div id="music-progress-thumb" class="absolute top-1/2 -translate-y-1/2 w-3 h-3 bg-white rounded-full shadow opacity-0 transition-opacity" style="left: 0%"></div>
							</div>
						</div>

						<div class="player-controls flex items-center justify-center gap-6">
							<button onclick="window.__fireflyMusic?.playPrev()" class="p-2 rounded-full hover:bg-(--btn-regular-bg) transition-colors">
								<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-5 h-5 text-(--deep-text)">
									<path d="M19 12H5M12 19l-7-7 7-7" />
								</svg>
							</button>
							<button onclick="window.__fireflyMusic?.togglePlay()" class="p-3 rounded-full bg-(--primary) text-white hover:opacity-90 transition-opacity">
								<svg id="player-toggle-icon" viewBox="0 0 24 24" fill="currentColor" class="w-6 h-6">
									<path d="M8 5v14l11-7z" />
								</svg>
							</button>
							<button onclick="window.__fireflyMusic?.playNext()" class="p-2 rounded-full hover:bg-(--btn-regular-bg) transition-colors">
								<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-5 h-5 text-(--deep-text)">
									<path d="M5 12h14M12 5l7 7-7 7" />
								</svg>
							</button>
						</div>

						<div class="player-mode mt-4 flex items-center justify-center gap-2">
							<button onclick="window.__fireflyMusic?.cyclePlayMode()" class="flex items-center gap-1 px-3 py-1.5 rounded-lg bg-(--btn-regular-bg) text-xs text-(--content-meta) hover:text-(--deep-text) transition-colors">
								<svg id="play-mode-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-3.5 h-3.5">
									<path d="M9 18V5l12-2v13" />
									<circle cx="6" cy="18" r="3" />
									<circle cx="18" cy="16" r="3" />
								</svg>
								<span id="play-mode-text">{i18n(I18nKey.musicPlayMode)}</span>
							</button>
							<button onclick="window.__fireflyMusic?.toggleMute()" class="flex items-center gap-1 px-3 py-1.5 rounded-lg bg-(--btn-regular-bg) text-xs text-(--content-meta) hover:text-(--deep-text) transition-colors">
								<svg id="volume-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-3.5 h-3.5">
									<polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5" />
									<path d="M19.07 4.93a10 10 0 0 1 0 14.14M15.54 8.46a5 5 0 0 1 0 7.07" />
								</svg>
							</button>
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>
</MainGridLayout>

<script define:vars={{ playlists: JSON.stringify(musicPlayerConfig.playlists) }}>
(function() {
	const playlists = JSON.parse(playlists);

	function renderTrackList(playlist) {
		const container = document.getElementById('music-track-list');
		if (!container || !playlist || playlist.length === 0) {
			container.innerHTML = '<div class="flex items-center justify-center py-12 text-(--content-meta)"><span class="text-sm">暂无歌曲</span></div>';
			return;
		}

		container.innerHTML = playlist.map((track, index) => `
			<div class="track-item grid grid-cols-12 gap-4 px-4 py-3 border-b border-(--line-divider)/50 hover:bg-(--btn-regular-bg) cursor-pointer transition-colors" onclick="window.__fireflyMusic?.playTrackByIndex(${index})">
				<div class="col-span-1 flex items-center justify-center">
					<span class="text-xs text-(--content-meta)">${index + 1}</span>
				</div>
				<div class="col-span-5 md:col-span-6 flex items-center">
					<div class="truncate">
						<div class="text-sm font-medium text-(--deep-text) truncate">${track.name || 'Unknown'}</div>
					</div>
				</div>
				<div class="col-span-4 md:col-span-3 flex items-center">
					<span class="text-xs text-(--content-meta) truncate">${track.artist || 'Unknown'}</span>
				</div>
				<div class="col-span-2 md:col-span-2 flex items-center justify-end">
					<span class="text-xs text-(--content-meta)">--:--</span>
				</div>
			</div>
		`).join('');
	}

	function updateCurrentLyric(lyrics, currentIndex) {
		const container = document.getElementById('music-current-lyric');
		if (!container) return;

		if (!lyrics || lyrics.length === 0 || currentIndex < 0) {
			container.textContent = '暂无歌词';
			return;
		}

		container.textContent = lyrics[currentIndex]?.text || '暂无歌词';
	}

	function updatePlayerUI(state) {
		const titleEl = document.getElementById('music-title');
		const artistEl = document.getElementById('music-artist');
		const coverEl = document.getElementById('music-cover');
		const coverPlaceholder = document.getElementById('music-cover-placeholder');
		const currentTimeEl = document.getElementById('music-current-time');
		const durationEl = document.getElementById('music-duration');
		const progressBar = document.getElementById('music-progress-bar');
		const progressThumb = document.getElementById('music-progress-thumb');
		const playBtnIcon = document.getElementById('music-play-btn-icon');
		const playBtnText = document.getElementById('music-play-btn-text');
		const playerToggleIcon = document.getElementById('player-toggle-icon');
		const playModeText = document.getElementById('play-mode-text');
		const volumeIcon = document.getElementById('volume-icon');

		if (state.track) {
			titleEl.textContent = state.track.name || '暂无播放';
			artistEl.textContent = state.track.artist || '-';

			if (state.track.pic) {
				coverEl.src = state.track.pic;
				coverEl.classList.remove('hidden');
				coverPlaceholder.classList.add('hidden');
			} else {
				coverEl.classList.add('hidden');
				coverPlaceholder.classList.remove('hidden');
			}
		}

		currentTimeEl.textContent = state.currentTimeStr || '0:00';
		durationEl.textContent = state.durationStr || '0:00';

		const progress = state.progress || 0;
		progressBar.style.width = progress + '%';
		progressThumb.style.left = progress + '%';

		if (state.isPlaying) {
			playBtnIcon.innerHTML = '<path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z" />';
			playBtnText.textContent = '暂停';
			playerToggleIcon.innerHTML = '<path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z" />';
		} else {
			playBtnIcon.innerHTML = '<path d="M8 5v14l11-7z" />';
			playBtnText.textContent = '播放';
			playerToggleIcon.innerHTML = '<path d="M8 5v14l11-7z" />';
		}

		playModeText.textContent = ['列表循环', '单曲循环', '随机播放'][state.playMode] || '播放模式';

		if (state.isMuted || state.volume === 0) {
			volumeIcon.innerHTML = '<polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5" /><line x1="23" y1="9" x2="17" y2="15" /><line x1="17" y1="9" x2="23" y2="15" />';
		} else if (state.volume < 0.5) {
			volumeIcon.innerHTML = '<polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5" /><path d="M15.54 8.46a5 5 0 0 1 0 7.07" />';
		} else {
			volumeIcon.innerHTML = '<polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5" /><path d="M19.07 4.93a10 10 0 0 1 0 14.14M15.54 8.46a5 5 0 0 1 0 7.07" />';
		}
	}

	function handleInit(e) {
		renderTrackList(e.detail.playlist);
		updatePlayerUI(window.__fireflyMusic?.getState());
	}

	function handleTrack(e) {
		updatePlayerUI(window.__fireflyMusic?.getState());
	}

	function handlePlayState(e) {
		updatePlayerUI(window.__fireflyMusic?.getState());
	}

	function handleTime(e) {
		updatePlayerUI(window.__fireflyMusic?.getState());
	}

	function handleLyrics(e) {
		updateCurrentLyric(e.detail.lyrics, -1);
	}

	function handleLrcIndex(e) {
		const state = window.__fireflyMusic?.getState();
		updateCurrentLyric(state?.lyrics || [], e.detail.index);
	}

	function handleMode(e) {
		updatePlayerUI(window.__fireflyMusic?.getState());
	}

	function handleVolume(e) {
		updatePlayerUI(window.__fireflyMusic?.getState());
	}

	function handlePlaylistChanged(e) {
		renderTrackList(e.detail.playlist);
		updatePlayerUI(window.__fireflyMusic?.getState());
	}

	window.addEventListener('fm:init', handleInit);
	window.addEventListener('fm:track', handleTrack);
	window.addEventListener('fm:play-state', handlePlayState);
	window.addEventListener('fm:time', handleTime);
	window.addEventListener('fm:lyrics', handleLyrics);
	window.addEventListener('fm:lrc-index', handleLrcIndex);
	window.addEventListener('fm:mode', handleMode);
	window.addEventListener('fm:volume', handleVolume);
	window.addEventListener('fm:playlist-changed', handlePlaylistChanged);

	document.addEventListener('click', function(e) {
		var playlistBtn = e.target.closest('.playlist-card');
		if (playlistBtn) {
			var playlistId = playlistBtn.dataset.playlistId;
			if (playlistId) {
				window.__fireflyMusic?.switchPlaylist(playlistId);
				document.querySelectorAll('.playlist-card').forEach(function(btn) {
					btn.classList.remove('border-(--primary)', 'bg-(--primary)/10');
					btn.classList.add('border-(--line-divider)', 'bg-(--card-bg)');
				});
				playlistBtn.classList.remove('border-(--line-divider)', 'bg-(--card-bg)');
				playlistBtn.classList.add('border-(--primary)', 'bg-(--primary)/10');
			}
		}
	});

	setTimeout(() => {
		window.__fireflyMusic?.init();
	}, 500);
})();
</script>

<style>
	.music-page-wrapper {
		border-radius: var(--radius-large);
	}

	.music-header {
		animation: fadeSlideIn 0.4s ease-[var(--ease-standard)] both;
	}

	@keyframes fadeSlideIn {
		from {
			opacity: 0;
			transform: translateY(8px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	.track-list::-webkit-scrollbar {
		width: 6px;
	}

	.track-list::-webkit-scrollbar-track {
		background: var(--btn-regular-bg);
	}

	.track-list::-webkit-scrollbar-thumb {
		background: var(--line-divider);
		border-radius: 3px;
	}

	.track-list::-webkit-scrollbar-thumb:hover {
		background: var(--content-meta);
	}

	.player-progress:hover #music-progress-thumb {
		opacity: 1;
	}

	@media (max-width: 640px) {
		.card-base {
			padding-left: 1rem;
			padding-right: 1rem;
			padding-top: 1.5rem;
			padding-bottom: 1.5rem;
		}

		.playlists-grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}
</style>
